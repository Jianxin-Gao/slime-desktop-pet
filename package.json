{
  "name": "desktop-pet",
  "version": "1.0.0",
  "description": "A cute desktop pet application",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "test": "echo \"Error: no test specified\" && exit 1",
    "pack:mac": "electron-builder --mac",
    "pack:win": "electron-builder --win"
  },
  "keywords": ["electron", "desktop", "pet"],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "electron": "^41.0.0",
    "electron-builder": "^26.8.1"
  },
  "build": {
    "appId": "com.my.desktoppet",
    "productName": "SlimePet",
    "mac": {
      "target": ["dmg", "zip"]
    },
    "win": {
      "target": ["nsis", "portable"]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
